<resources xmlns:tools="http://schemas.android.com/tools">
    
    <!-- Material Design 3 Healthcare Theme -->
    <style name="Theme.HealthSenseAI" parent="Theme.Material3.Light.NoActionBar">
        <!-- Primary Colors -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorPrimaryContainer">@color/colorPrimaryVariant</item>
        <item name="colorOnPrimaryContainer">@color/colorOnPrimary</item>
        
        <!-- Secondary Colors -->
        <item name="colorSecondary">@color/colorSecondary</item>
        <item name="colorOnSecondary">@color/colorOnSecondary</item>
        <item name="colorSecondaryContainer">@color/colorSecondaryVariant</item>
        <item name="colorOnSecondaryContainer">@color/colorOnSecondary</item>
        
        <!-- Background & Surface -->
        <item name="android:windowBackground">@color/colorBackground</item>
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorSurfaceVariant">@color/colorSurfaceVariant</item>
        <item name="colorOnSurface">@color/colorOnSurface</item>
        <item name="colorOnSurfaceVariant">@color/colorOnSurfaceVariant</item>
        
        <!-- Error Colors -->
        <item name="colorError">@color/colorError</item>
        <item name="colorOnError">@color/colorOnError</item>
        
        <!-- Status Bar -->
        <item name="android:statusBarColor">@color/colorBackground</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Typography -->
         <item name="textAppearanceHeadline1">@style/TextAppearance.HealthSenseAI.Headline1</item>
        <item name="textAppearanceHeadline2">@style/TextAppearance.HealthSenseAI.Headline2</item>
        <item name="textAppearanceBody1">@style/TextAppearance.HealthSenseAI.Body1</item>
    </style>
    
    <!-- Custom Text Appearances -->
    <style name="TextAppearance.HealthSenseAI.Headline1" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:textColor">@color/colorPrimary</item> <!-- Use primary color for main headers -->
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">28sp</item>
    </style>
    
    <style name="TextAppearance.HealthSenseAI.Headline2" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/colorOnSurface</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <style name="TextAppearance.HealthSenseAI.Body1" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">@color/colorOnSurfaceVariant</item>
    </style>

    <!-- Card Style -->
    <style name="Widget.HealthSenseAI.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/colorSurface</item>
        <item name="cardElevation">4dp</item>
        <item name="cardCornerRadius">20dp</item> <!-- Softer corners -->
        <item name="android:layout_margin">8dp</item>
        <item name="strokeColor">@android:color/transparent</item> <!-- No border for cleaner look -->
    </style>
    
    <!-- Button Style -->
    <style name="Widget.HealthSenseAI.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/colorPrimary</item>
        <item name="android:textColor">@color/colorOnPrimary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingVertical">12dp</item>
    </style>

</resources>