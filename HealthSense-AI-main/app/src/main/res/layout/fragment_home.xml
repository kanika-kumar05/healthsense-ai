<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome Back,"
                style="@style/TextAppearance.HealthSenseAI.Body1"
                android:textStyle="bold"
                android:alpha="0.7"/>
                
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Health Overview"
                style="@style/TextAppearance.HealthSenseAI.Headline1"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Smartwatch Connection Banner -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardSmartwatch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="10dp"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp"
                android:orientation="horizontal"
                android:background="@drawable/watch_card_gradient">

                <!-- WATCH IMAGE -->
                <ImageView
                    android:id="@+id/watchImage"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:src="@drawable/ic_watch"
                    android:layout_gravity="center_vertical"
                    android:contentDescription="Smartwatch"/>

                <!-- CENTER INFO -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        
                        <TextView
                            android:id="@+id/tvSmartwatchTitle"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="Smartwatch"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="#0F172A"/>

                        <LinearLayout
                            android:id="@+id/layoutConnected"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:paddingTop="6dp"
                            android:paddingBottom="6dp"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:background="@drawable/connected_badge">

                            <View
                                android:id="@+id/dotConnected"
                                android:layout_width="8dp"
                                android:layout_height="8dp"
                                android:layout_marginEnd="6dp"
                                android:background="@drawable/pulse_dot_green"/>

                            <TextView
                                android:id="@+id/tvConnectedText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Connected"
                                android:textColor="#16A34A"
                                android:textStyle="bold"
                                android:textSize="13sp"/>
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvDeviceName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FitSense Watch Series 4"
                        android:textSize="14sp"
                        android:textColor="#475569"
                        android:layout_marginTop="4dp"/>

                    <!-- BATTERY + SYNC -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🔋 "
                            android:textColor="#334155"
                            android:textSize="13sp"/>
                            
                        <ProgressBar
                            android:id="@+id/pbBattery"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="40dp"
                            android:layout_height="8dp"
                            android:progressDrawable="@drawable/battery_progress_drawable"
                            android:max="100"
                            android:progress="82"
                            android:layout_marginEnd="4dp"/>

                        <TextView
                            android:id="@+id/tvBattery"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="82%"
                            android:textColor="#334155"
                            android:textSize="13sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="  |  "
                            android:textColor="#64748B"/>

                        <TextView
                            android:id="@+id/tvLastSync"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Last Sync: Just now"
                            android:textSize="13sp"
                            android:textColor="#334155"/>

                    </LinearLayout>

                    <!-- BUTTONS -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnSync"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="40dp"
                            android:text="Sync"
                            android:textAllCaps="false"
                            android:backgroundTint="#3B82F6"
                            android:textColor="@android:color/white"
                            android:layout_marginEnd="8dp"/>

                        <Button
                            android:id="@+id/btnDeviceInfo"
                            android:layout_width="0dp"
                            android:layout_weight="1.2"
                            android:layout_height="40dp"
                            android:text="Device Info"
                            android:textAllCaps="false"
                            android:backgroundTint="#E2E8F0"
                            android:textColor="#1E293B"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- CONNECTED BADGE MOVED -->

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Predicted Risk Banner -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            style="@style/Widget.HealthSenseAI.Card"
            app:cardBackgroundColor="@color/colorSecondaryContainer">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Prediction Analysis"
                    style="@style/TextAppearance.Material3.LabelMedium"
                    android:textColor="@color/colorOnSecondaryContainer"
                    android:layout_marginBottom="8dp"/>
                    
                <TextView
                    android:id="@+id/predictedRisk"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/predicted_risk"
                    style="@style/TextAppearance.Material3.TitleMedium"
                    android:textColor="@color/colorOnSecondaryContainer"
                    android:textStyle="bold"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Grid Row 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <!-- Heart Rate Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                style="@style/Widget.HealthSenseAI.Card">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">
                    
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_heart"
                        app:tint="@color/colorError"
                        android:layout_marginBottom="8dp"/>
                        
                    <TextView
                        android:id="@+id/heartRateValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="26sp"
                        android:textStyle="bold"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Heart Rate"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SpO2 Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                style="@style/Widget.HealthSenseAI.Card">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">
                    
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_drop"
                        app:tint="@color/colorError"
                        android:layout_marginBottom="8dp"/>
                        
                    <TextView
                        android:id="@+id/spo2Value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="26sp"
                        android:textStyle="bold"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SpO₂"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Grid Row 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <!-- Stress Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                style="@style/Widget.HealthSenseAI.Card">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">
                    
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_stress"
                        app:tint="@color/colorWarning"
                        android:layout_marginBottom="8dp"/>
                        
                    <TextView
                        android:id="@+id/stressValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="26sp"
                        android:textStyle="bold"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stress Lvl"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Sleep Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                style="@style/Widget.HealthSenseAI.Card">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:gravity="center">
                    
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_moon"
                        app:tint="@color/colorTertiary"
                        android:layout_marginBottom="8dp"/>
                        
                    <TextView
                        android:id="@+id/sleepValue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--"
                        android:textColor="?attr/colorOnSurface"
                        android:textSize="26sp"
                        android:textStyle="bold"/>
                        
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sleep"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textSize="12sp"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
        
        <!-- Grid Row 3 (Breath Rate) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <!-- Breath Rate Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.HealthSenseAI.Card">
                
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">
                    
                    <ImageView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@drawable/ic_lungs"
                        app:tint="@color/colorPrimary"
                        android:layout_marginEnd="16dp"/>
                    
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                         <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Breath Rate"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:textSize="12sp"/>
                        <TextView
                            android:id="@+id/breathRateValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="?attr/colorOnSurface"
                            android:textSize="26sp"
                            android:textStyle="bold"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewInsights"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/view_detailed_insights"
            style="@style/Widget.HealthSenseAI.Button"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>