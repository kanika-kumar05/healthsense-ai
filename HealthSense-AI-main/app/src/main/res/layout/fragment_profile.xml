<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Profile Header Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            style="@style/Widget.HealthSenseAI.Card">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:gravity="center_horizontal">
                
                <!-- Avatar Icon -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    app:cardCornerRadius="40dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/colorSecondaryContainer"
                    android:layout_marginBottom="16dp">
                    
                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_heart"
                        app:tint="@color/colorSecondary"
                        android:layout_gravity="center"/>
                </com.google.android.material.card.MaterialCardView>
                
                <!-- User Name -->
                <TextView
                    android:id="@+id/userName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kuldeep"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorOnSurface"
                    android:layout_marginBottom="8dp"/>
                
                <!-- Smartwatch Status -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">
                    
                    <View
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/ic_heart"
                        android:backgroundTint="@color/colorSuccess"
                        android:layout_marginEnd="8dp"/>
                    
                    <TextView
                        android:id="@+id/smartwatchStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NoiseFit — Connected"
                        android:textColor="@color/colorOnSurfaceVariant"
                        android:textSize="14sp"/>
                </LinearLayout>
                
                <!-- Stats Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginTop="8dp">
                    
                    <!-- Health Score -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        
                        <TextView
                            android:id="@+id/healthScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="92/100"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorSuccess"/>
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Health Score"
                            android:textSize="12sp"
                            android:textColor="@color/colorOnSurfaceVariant"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                    
                    <View
                        android:layout_width="1dp"
                        android:layout_height="40dp"
                        android:background="@color/medicalGrayLight"/>
                    
                    <!-- Account Created -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">
                        
                        <TextView
                            android:id="@+id/accountCreated"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jan 2026"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/colorOnSurface"/>
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Member Since"
                            android:textSize="12sp"
                            android:textColor="@color/colorOnSurfaceVariant"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Action Buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEditProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Edit Profile"
            android:layout_marginBottom="12dp"
            style="@style/Widget.HealthSenseAI.Button"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSelfAssessment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Self-Assessment"
            android:layout_marginBottom="12dp"
            style="@style/Widget.Material3.Button.OutlinedButton"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Logout"
            android:layout_marginBottom="24dp"
            android:backgroundTint="@color/colorError"
            android:textColor="@color/colorOnError"
            style="@style/Widget.HealthSenseAI.Button"/>

        <!-- Settings Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/Widget.HealthSenseAI.Card">
            
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Settings"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorOnSurface"
                    android:layout_marginBottom="16dp"/>
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="App Info"
                    android:textSize="16sp"
                    android:textColor="@color/colorOnSurface"
                    android:paddingVertical="12dp"/>
                
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/medicalGrayLight"/>
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Privacy"
                    android:textSize="16sp"
                    android:textColor="@color/colorOnSurface"
                    android:paddingVertical="12dp"/>
                
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/medicalGrayLight"/>
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Terms"
                    android:textSize="16sp"
                    android:textColor="@color/colorOnSurface"
                    android:paddingVertical="12dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
